node_modules/
**/node_modules/

# Build outputs
dist/
**/dist/
mobile-runtime-platform/apps/desktop/build/
mobile-runtime-platform/apps/desktop/native/winembed/build/
*.tsbuildinfo

# Runtime outputs
mobile-runtime-platform/uploads/*
!mobile-runtime-platform/uploads/.gitkeep
mobile-runtime-platform/services/backend-api/uploads/*
!mobile-runtime-platform/services/backend-api/uploads/.gitkeep
mobile-runtime-platform/artifacts/jobs/*
!mobile-runtime-platform/artifacts/jobs/.gitkeep

# Logs/temp
*.log
tmp/
temp/

# Windows-only generated binaries/artifacts
*.exe
*.dll
*.pdb
*.lib
*.exp
*.iobj
*.ipdb
*.ilk
*.obj
*.idb
*.tlog
*.bin
*.blockmap

# OS/editor noise
.DS_Store
Thumbs.db
Desktop.ini
# prevent nested git metadata backups
**/.git.backup/
